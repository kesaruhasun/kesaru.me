{
  "apps": [
    {
      "name": "kesaru-portfolio",
      "script": "npm",
      "args": "start",
      "cwd": "/var/www/kesaru.me",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      },
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "merge_logs": true,
      "log_date_format": "YYYY-MM-DD HH:mm Z",
      "error_file": "/var/log/pm2/kesaru-portfolio-error.log",
      "out_file": "/var/log/pm2/kesaru-portfolio-out.log",
      "log_file": "/var/log/pm2/kesaru-portfolio-combined.log"
    }
  ]
}
